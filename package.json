{
  "name": "otto",
  "private": true,
  "description": "AI design tool with infinite canvas — vibe coding for design",
  "keywords": [],
  "license": "AGPL-3.0-only",
  "author": "Stratus Labs LLC",
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo run start",
    "proto:gen": "protoc --plugin=protoc-gen-ts_proto=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=./src/gen --ts_proto_opt=outputServices=nice-grpc,outputClientImpl=connect-web ./proto/canvas.proto",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-node": "^2.1.1",
    "@types/react": "^19.2.14",
    "nice-grpc-common": "^2.0.0",
    "react": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "oxfmt": "^0.7.0",
    "oxlint": "^0.7.0",
    "ts-proto": "^2.11.5",
    "turbo": "latest",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.6.3"
}
